# Copy this file to `.env` and fill in real values.

# --- Database ---
# Local dev uses SQLite (no setup). For production, switch the datasource
# provider in prisma/schema.prisma to "postgresql" and put your Neon URL here.
DATABASE_URL="file:./dev.db"

# --- Admin dashboard (/admin) ---
ADMIN_PASSWORD="choose-a-strong-password"
# Must be at least 32 characters (used to sign the session cookie).
SESSION_SECRET="change-me-to-a-random-string-at-least-32-chars"

# --- Email (Resend) ---
# Leave RESEND_API_KEY empty to log emails to the console in dev instead of sending.
RESEND_API_KEY=""
FROM_EMAIL="KoureshCuts <bookings@yourdomain.com>"

# --- Cron (day-before reminders) ---
# Vercel Cron sends this as a Bearer token to /api/cron/reminders.
CRON_SECRET="change-me-random-string"

# --- Admin calendar subscription feed ---
# Token embedded in the /api/admin/calendar feed URL for calendar subscriptions.
ICS_FEED_TOKEN="change-me-random-string"

# --- Public site URL ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
