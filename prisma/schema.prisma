// KoureshCuts booking database.
//
// Developed against SQLite for zero-setup local dev. To deploy on Neon/Vercel
// Postgres: change `provider` to "postgresql", point DATABASE_URL at Neon, then
// run `npx prisma migrate reset` (fresh project) or `npx prisma db push`.
// The schema is intentionally Postgres-portable: no SQLite-only types, statuses
// stored as plain strings (see AppointmentStatus in src/lib/constants.ts),
// money as integer cents, durations/hours as integer minutes, times as UTC.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  // Pooled connection (PgBouncer) for serverless runtime.
  url       = env("DATABASE_URL")
  // Direct connection for migrations / `prisma db push`.
  directUrl = env("DATABASE_URL_UNPOOLED")
}

/// A bookable service (haircut, beard trim, etc.).
model Service {
  id              String         @id @default(cuid())
  name            String
  description     String         @default("")
  durationMinutes Int
  priceCents      Int
  active          Boolean        @default(true)
  sortOrder       Int            @default(0)
  appointments    Appointment[]
  waitlist        WaitlistEntry[]
  createdAt       DateTime       @default(now())
}

/// Weekly opening-hours template, one row per weekday (0 = Sunday … 6 = Saturday).
/// openMinute/closeMinute are minutes from midnight in the business timezone.
model BusinessHours {
  id          String  @id @default(cuid())
  dayOfWeek   Int     @unique
  openMinute  Int     @default(540) // 09:00
  closeMinute Int     @default(1020) // 17:00
  isClosed    Boolean @default(false)
}

/// Singleton row of editable shop settings.
model Settings {
  id                String   @id @default("singleton")
  /// How many days ahead customers may book (the public booking window).
  bookingWindowDays Int      @default(28)
  /// Whether day-of reminder emails are sent at all.
  reminderEnabled   Boolean  @default(true)
  /// How many hours before the appointment the reminder is sent.
  reminderLeadHours Int      @default(24)
  /// Until how many hours before the start customers may cancel/reschedule
  /// online (0 = up to the start time).
  cancelDeadlineHours Int    @default(0)
  /// Max simultaneous upcoming bookings per customer email (0 = unlimited).
  maxActiveBookingsPerEmail Int @default(0)
  /// No-shows after which an email loses online booking (0 = never block).
  noShowBlockThreshold Int @default(2)
  /// Win-back email after N weeks without a visit (0 = off).
  winbackWeeks Int @default(0)
  /// Owner-copy mails (new booking, waitlist, cancellation notices). Off =
  /// "Mail-Sparmodus": the owner relies on push only, halving daily volume.
  ownerCopyEmails   Boolean  @default(true)
  updatedAt         DateTime @updatedAt
}

/// A blocked-out date range (vacation, day off). Inclusive of both dates.
/// `emergency` marks a short-notice closure (Notfall-Knopf) — the public site
/// shows a red "kurzfristig geschlossen" banner while it covers today.
model TimeOff {
  id        String   @id @default(cuid())
  startDate DateTime
  endDate   DateTime
  reason    String   @default("")
  emergency Boolean  @default(false)
  createdAt DateTime @default(now())
}

/// An extra working day on a single date that the weekly template would
/// otherwise leave closed. `date` is the start-of-day UTC instant for the shop
/// timezone. When `isPublic` is true the day is offered in the public booking
/// calendar; when false it is only a working-day marker for the admin agenda.
model SpecialDay {
  id          String   @id @default(cuid())
  date        DateTime @unique
  openMinute  Int      @default(540) // 09:00
  closeMinute Int      @default(1020) // 17:00
  isPublic    Boolean  @default(true)
  note        String   @default("")
  createdAt   DateTime @default(now())

  @@index([date])
}

/// A customer appointment. PENDING/CONFIRMED occupy the slot; CANCELLED frees it.
model Appointment {
  id             String    @id @default(cuid())
  service        Service   @relation(fields: [serviceId], references: [id])
  serviceId      String
  customerName   String
  customerEmail  String
  customerPhone  String
  startTime      DateTime
  endTime        DateTime
  status         String    @default("CONFIRMED")
  notes          String    @default("")
  reminderSentAt DateTime?
  createdAt      DateTime  @default(now())

  @@index([startTime])
  @@index([status])
}

/// Delay minutes assigned to a customer ("Minutenkonto"): every time a
/// customer shows up late the admin logs the minutes; the Verspätungen tab
/// sums them per customer. `date` is the start-of-day UTC instant for the
/// shop timezone. Customers are keyed by lowercase email (name as fallback).
model DelayLog {
  id            String   @id @default(cuid())
  date          DateTime
  minutes       Int
  customerName  String   @default("")
  customerEmail String   @default("")
  note          String   @default("")
  notified      Int      @default(0)
  createdAt     DateTime @default(now())

  @@index([date])
  @@index([customerEmail])
}

/// A manually blocked customer email (admin decision): no online booking.
/// Emails are stored lowercase. Separate from the automatic no-show block.
model BlockedCustomer {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String   @default("")
  createdAt DateTime @default(now())
}

/// Customers who unsubscribed from broadcast/news emails (lowercase). Only
/// affects Rundmails — transactional emails (confirmations etc.) still go out.
model EmailOptOut {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

/// Customers (lowercase email) whose online bookings need manual approval:
/// the appointment is created PENDING and only confirmed by the owner.
/// A softer step than the full BlockedCustomer block.
model ReviewCustomer {
  id        String   @id @default(cuid())
  email     String   @unique
  reason    String   @default("")
  createdAt DateTime @default(now())
}

/// Tracks the win-back email per customer (lowercase) so each booking lapse
/// triggers at most one "we miss you" mail (re-sent only after a new visit).
model WinbackLog {
  id     String   @id @default(cuid())
  email  String   @unique
  sentAt DateTime
}

/// One tracked page view for the admin Statistik tab. Privacy-light: no IP or
/// raw user agent is stored — `visitor` is a daily-rotating salted hash used
/// only to count unique visitors. Old rows are pruned by the daily cron.
model PageView {
  id        String   @id @default(cuid())
  /// "yyyy-MM-dd" in the shop timezone.
  day       String
  path      String
  referrer  String   @default("")
  device    String   @default("")
  visitor   String
  createdAt DateTime @default(now())

  @@index([day])
}

/// An email that Resend refused to send (e.g. the free-plan daily limit).
/// Stored fully rendered so the daily 07:00 cron — or the admin's "retry now"
/// button — can resend it verbatim. Rows are pruned after 14 days; after 4
/// failed attempts a mail is given up on.
model EmailFailure {
  id        String    @id @default(cuid())
  to        String
  subject   String
  html      String
  error     String    @default("")
  attempts  Int       @default(1)
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([sentAt])
}

/// A Web-Push subscription of the admin PWA (owner's phone/browser). Every
/// subscription receives a push notification on new bookings/cancellations.
model PushSubscription {
  id        String   @id @default(cuid())
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())
}

/// A customer device watching for freed slots ("Termin-Radar"). `date` set =
/// watching one specific day; null = any day. Day watchers are pushed at most
/// once (notifiedAt), flexible watchers at most once per 24h. Stale rows are
/// removed by the daily cron.
model CustomerPush {
  id         String    @id @default(cuid())
  endpoint   String    @unique
  p256dh     String
  auth       String
  date       DateTime?
  /// Customer email (lowercase) when known — enables reminder pushes.
  email      String    @default("")
  notifiedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([date])
  @@index([email])
}

/// A customer waiting for a spot. `date` set = waiting for that specific day
/// (start-of-day UTC for the shop timezone); `date` null = flexible entry
/// ("next free slot"), optionally restricted to `weekdays` (CSV of
/// 0=Sunday…6=Saturday; empty = any day). The admin assigns appointments from
/// this list directly; `notifiedAt` tracks the manual "spot free" mail.
model WaitlistEntry {
  id            String    @id @default(cuid())
  service       Service   @relation(fields: [serviceId], references: [id])
  serviceId     String
  date          DateTime?
  weekdays      String    @default("")
  customerName  String
  customerEmail String
  notifiedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([date])
}
